# OpenAI API Key (required)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Model overrides (optional) ──
# 비우면 src/lib/agents/model-config.ts의 기본값을 사용합니다.
# 사용 가능 여부는 `npm run check:models`로 확인하세요.
#
# 모든 에이전트·도구가 사용 (에이전트 추론, ATS 분석, 이력서 파싱, 불릿 개선)
OPENAI_MODEL_STANDARD=
# 현재 코드에서 미사용 — 비용을 낮춰야 할 때를 위한 예약 레버
OPENAI_MODEL_FAST=
