# OpenAI API Key (required)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Model overrides (optional) ──
# 비우면 src/lib/agents/model-config.ts의 기본값을 사용합니다.
# 사용 가능 여부는 `npm run check:models`로 확인하세요.
#
# 품질이 중요한 작업 (에이전트 추론, ATS 분석, 매칭)
OPENAI_MODEL_STANDARD=
# 빠르고 저렴해야 하는 작업 (이력서 파싱, 불릿 개선)
OPENAI_MODEL_FAST=
