# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# cloudflare
.open-next/
.wrangler/

# presentation (local only)
presentation/

# docs build artifacts (regenerate with docs/generate_*.mjs)
docs/*.pdf
docs/*.docx

# regenerated by scripts/verify/browser.mjs on every run
scripts/verify/fixture-resume.pdf

# claude code
.claude/
FABLE5-PROMPT.md

# typescript
*.tsbuildinfo
next-env.d.ts
