{
  "name": "myofferagent-com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test && npm run build",
    "check:models": "node scripts/check-models.mjs",
    "cf:build": "npx @opennextjs/cloudflare build",
    "cf:preview": "npm run cf:build && npx wrangler dev",
    "cf:deploy": "npm run cf:build && npx wrangler deploy"
  },
  "dependencies": {
    "@openai/agents": "^0.6.0",
    "docx": "^9.7.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.10",
    "pdfjs-dist": "^5.5.207",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "hono": "^4.12.7",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.7",
    "wrangler": "^4.71.0"
  }
}
